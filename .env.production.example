COMPOSE_PROJECT_NAME=petswipe

# Image configuration
BACKEND_IMAGE=ghcr.io/your-org/petswipe-backend
BACKEND_TAG=stable
FRONTEND_IMAGE=ghcr.io/your-org/petswipe-frontend
FRONTEND_TAG=stable

# Frontend runtime/build configuration
NEXT_PUBLIC_API_URL=https://api.petswipe.example.com/api

# Backend runtime configuration
NODE_ENV=production
PORT=5001
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES=1h
DB_HOST=db
DB_PORT=5432
DB_USER=petswipe
DB_PASS=replace-me
DB_NAME=petswipe
DB_SSL=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
S3_BUCKET=petswipe-uploads-production

# Database bootstrap
POSTGRES_USER=petswipe
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=petswipe

# Grafana
GRAFANA_PASSWORD=replace-me

